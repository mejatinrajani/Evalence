# Evalence Platform - Environment Configuration Template
# Copy this file to .env and fill in your actual values

# ===================================
# Database Configuration
# ===================================
# For Neon PostgreSQL: Get URL from Neon Dashboard
# Format: postgresql+psycopg2://user:password@host/dbname?sslmode=require
DATABASE_URL=postgresql+psycopg2://user:password@host/dbname?sslmode=require&channel_binding=require

# ===================================
# Email Configuration (Gmail SMTP)
# ===================================
# 1. Enable 2-Factor Authentication on Google Account
# 2. Generate App Password: https://myaccount.google.com/apppasswords
# 3. Use the 16-character App Password below (remove spaces)
SENDER_EMAIL=your-email@gmail.com
SENDER_PASSWORD=xxxx xxxx xxxx xxxx
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587

# ===================================
# Security Configuration
# ===================================
# IMPORTANT: Generate a secure random key:
# python -c "import secrets; print(secrets.token_urlsafe(32))"
# 
# Never commit real SECRET_KEY to version control!
SECRET_KEY=your-secret-key-here-generate-new-one

# ===================================
# Environment
# ===================================
# development | staging | production
ENVIRONMENT=development

# Frontend URL (for email links)
FRONTEND_URL=http://localhost:5173

# ===================================
# API Configuration
# ===================================
# API Host and Port
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true
